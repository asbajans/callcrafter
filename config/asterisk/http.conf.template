;
; CallCrafter - HTTP/HTTPS Configuration Template
; Copy to /etc/asterisk/http.conf
;

[general]
enabled = yes
bindaddr = 0.0.0.0
bindport = 8088

; WebSocket for WebRTC
wsbinding = 0.0.0.0:8088
wssbinding = 0.0.0.0:8089
tlsenable = yes
tlsbindaddr = 0.0.0.0:8089
tlscertfile = /etc/asterisk/keys/asterisk.pem
tlsprivatekey = /etc/asterisk/keys/asterisk-key.pem
