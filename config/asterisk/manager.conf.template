;
; CallCrafter - Asterisk Manager Interface Configuration
; Copy to /etc/asterisk/manager.conf
;

[general]
enabled = yes
port = 5038
bindaddr = 0.0.0.0

[admin]
secret = admin
permit = 0.0.0.0/0.0
read = system,call,log,verbose,agent,user,config,dtmf,reporting,cdr,dialplan,bridge
write = system,call,agent,user,config,command,reporting,originate
